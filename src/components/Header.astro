---
import type { CollectionEntry } from 'astro:content';

interface Props {
  site: CollectionEntry<'site'>;
}

const { site } = Astro.props;
const { nav, siteName } = site.data;
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-iso-dark/90 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
    <a href="#home" class="group flex shrink-0 flex-col leading-tight">
      <span class="font-display text-sm font-bold tracking-wide text-red-500 sm:text-base">
        {siteName}
      </span>
      <span class="hidden text-[10px] uppercase tracking-widest text-white/50 sm:block">
        No Patience. No Remorse. No Apologies.
      </span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {
        nav.map((link) => (
          <a
            href={link.href}
            class="rounded-md px-3 py-2 text-xs font-semibold uppercase tracking-wide text-white/80 transition hover:bg-white/5 hover:text-white"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <a
      href="#acquisition"
      class="hidden rounded-md border border-red-500/40 bg-red-500/10 px-3 py-2 text-xs font-bold uppercase tracking-wide text-red-400 transition hover:bg-red-500/20 sm:inline-flex"
    >
      Acquire Domain
    </a>

    <details class="relative lg:hidden">
      <summary
        class="list-none cursor-pointer rounded-md border border-white/15 px-3 py-2 text-xs font-bold uppercase tracking-wide text-white"
      >
        Menu
      </summary>
      <nav
        class="absolute right-0 mt-2 w-56 rounded-lg border border-white/10 bg-iso-dark p-2 shadow-xl"
        aria-label="Mobile"
      >
        {
          nav.map((link) => (
            <a
              href={link.href}
              class="block rounded-md px-3 py-2 text-sm font-medium text-white/85 hover:bg-white/5"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="#acquisition"
          class="mt-1 block rounded-md bg-red-500/15 px-3 py-2 text-sm font-semibold text-red-400"
        >
          Acquire Domain
        </a>
      </nav>
    </details>
  </div>
</header>
