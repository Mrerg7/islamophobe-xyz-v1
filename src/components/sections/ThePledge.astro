---
import type { CollectionEntry } from 'astro:content';

interface Props {
  site: CollectionEntry<'site'>;
}

const { site } = Astro.props;
const { thePledge } = site.data;
---

<section id="the-pledge" class="relative py-24 sm:py-32 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="relative overflow-hidden rounded-3xl border border-red-500/20 bg-gradient-to-br from-iso-dark via-[#120a0a] to-red-950/30 p-8 sm:p-12">
      <div
        class="absolute -top-24 -right-24 w-64 h-64 rounded-full bg-red-500/10 blur-3xl pointer-events-none"
        aria-hidden="true"
      ></div>

      <div class="relative z-10">
        <h2 class="section-header text-white mb-4 text-center">
          The <span class="text-gradient-red">No-Apologies</span> Pledge
        </h2>
        <p class="text-center text-white/60 mb-10 text-lg">
          {thePledge.intro}
        </p>

        <div class="space-y-5 mb-10 max-w-2xl mx-auto">
          {thePledge.lines.map((line: string) => (
            <p class="flex items-start gap-x-3 text-lg text-white/80 leading-relaxed">
              <span class="text-red-500 mt-1 shrink-0 text-xl">✕</span>
              <span>{line}</span>
            </p>
          ))}
        </div>

        <!-- Signature Lines -->
        <div class="max-w-xl mx-auto space-y-6">
          <div class="border-b-2 border-red-500/30 pb-3">
            <p class="text-xs uppercase tracking-widest text-red-400/60 mb-2">{thePledge.signatureLabel}</p>
            <div class="h-8"></div>
          </div>
          <div class="border-b-2 border-red-500/30 pb-3">
            <p class="text-xs uppercase tracking-widest text-red-400/60 mb-2">{thePledge.generationLabel}</p>
            <div class="h-8"></div>
          </div>
        </div>

        <p class="mt-10 text-center text-xl text-red-400 font-bold">
          {thePledge.closingLine}
        </p>
      </div>
    </div>
  </div>
</section>
