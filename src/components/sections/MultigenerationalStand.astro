---
import type { CollectionEntry } from 'astro:content';

interface Props {
  site: CollectionEntry<'site'>;
}

const { site } = Astro.props;
const { multigenerationalStand } = site.data;
---

<section class="relative py-24 sm:py-32 px-6 bg-white/[0.02]">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="section-header text-white mb-12">
      The <span class="text-gradient-fire">Multi-Generational</span> Stand
    </h2>
    <div class="space-y-6 text-lg text-white/70 leading-relaxed max-w-3xl mx-auto">
      {multigenerationalStand.paragraphs.map((p) => (
        <p>{p}</p>
      ))}
    </div>
  </div>
</section>
