---
import type { CollectionEntry } from 'astro:content';
import { acquisitionMailto } from '../lib/site';

interface Props {
  site: CollectionEntry<'site'>;
}

const { site } = Astro.props;
const { footer, siteName, acquisitionEmail } = site.data;
const mailto = acquisitionMailto();
---

<footer class="border-t border-white/10 bg-iso-black">
  <!-- Domain Acquisition CTA -->
  <section
    id="acquisition"
    class="relative overflow-hidden border-b border-red-500/20 bg-gradient-to-br from-iso-dark via-[#120a0a] to-iso-red-deeper/40"
  >
    <div
      class="pointer-events-none absolute inset-0 opacity-30"
      style="background-image: radial-gradient(circle at 80% 20%, rgba(220,38,38,0.25), transparent 40%);"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-4xl px-4 py-14 text-center sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-[0.25em] text-red-400">Domain Portfolio</p>
      <h2 class="mt-3 font-display text-2xl font-bold text-white sm:text-3xl">
        {footer.acquisitionHeadline}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-white/75">
        {footer.acquisitionBody}
      </p>
      <div
        class="mt-8 inline-flex flex-col items-center gap-3 rounded-2xl border border-red-500/30 bg-black/30 px-8 py-6 backdrop-blur-sm"
      >
        <span class="text-sm text-white/60">islamophobe.xyz</span>
        <a
          href={mailto}
          class="pulse-cta inline-flex items-center gap-2 rounded-lg bg-red-600 px-8 py-4 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-red-500"
        >
          {footer.acquisitionCta}
        </a>
        <a
          href={`mailto:${acquisitionEmail}`}
          class="font-mono text-sm text-red-400 hover:underline"
        >
          {acquisitionEmail}
        </a>
        <p class="text-[11px] text-white/40">Confidential inquiries · Response within 24 hours</p>
      </div>
    </div>
  </section>

  <!-- Main footer content -->
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 border-b border-white/10 pb-8 md:flex-row md:items-start md:justify-between">
      <div>
        <p class="font-display text-lg font-bold text-white">{siteName}</p>
        <p class="mt-2 max-w-md text-sm text-white/65">{footer.tagline}</p>
      </div>
      <p class="max-w-lg text-xs leading-relaxed text-white/50">
        Data sources: Pew Research Center, U.S. House Judiciary Committee (2026), U.S. Department of Justice
      </p>
    </div>

    <p class="mt-6 text-center text-xs text-white/40">
      Not affiliated with any political party or candidate
    </p>

    <p class="mx-auto mt-6 max-w-3xl text-center text-[11px] leading-relaxed text-white/45">
      {footer.disclaimer}
    </p>

    <p class="mt-8 text-center text-xs text-white/50">{footer.copyright}</p>

    <p class="mt-4 text-center text-sm font-bold text-red-500/80">{footer.finalLine}</p>
  </div>
</footer>
